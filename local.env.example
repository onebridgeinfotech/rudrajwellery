# Copy to local.env and set your local WordPress install paths.
# Used by scripts/sync-local.ps1 before push/deploy.

# URL to open in browser for preview (homepage or shop)
LOCAL_SITE_URL=http://localhost:10008

# Full path to local theme folder (must end with jwellery-jewelry)
# Local WP example: C:\Users\YOU\Local Sites\mysite\app\public\wp-content\themes\jwellery-jewelry
LOCAL_WP_THEME_PATH=

# Full path to local plugin folder
LOCAL_WP_PLUGIN_PATH=
