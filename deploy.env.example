# Copy to .env.deploy and fill in Hostinger FTP details.
# .env.deploy is gitignored — never commit real passwords.

FTP_SERVER=82.180.143.137
FTP_USERNAME=your-ftp-username
FTP_PASSWORD=your-ftp-password
FTP_PORT=21
FTP_PROTOCOL=ftp

# Enable in hPanel: Advanced → Remote Access → SSH/SFTP ON

# Remote paths — Hostinger FTP root is often the WordPress root (not /public_html/...)
FTP_REMOTE_THEME=/wp-content/themes/jwellery-jewelry/
FTP_REMOTE_PLUGIN=/wp-content/plugins/jewelry-upi-store/

# Optional: SSH key deploy (recommended). Run scripts/generate-deploy-key.ps1
# SFTP_PRIVATE_KEY_PATH=D:\jwellery ecommerce\scripts\.deploy-keys\github_deploy
