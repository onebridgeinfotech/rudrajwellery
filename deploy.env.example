# Copy to .env.deploy and fill in Hostinger FTP details.
# .env.deploy is gitignored — never commit real passwords.

FTP_SERVER=82.180.143.137
FTP_USERNAME=your-ftp-username
FTP_PASSWORD=your-ftp-password
FTP_PORT=65002
FTP_PROTOCOL=sftp

# Enable in hPanel: Advanced → Remote Access → SSH/SFTP ON

# Remote paths (usually correct for Hostinger WordPress)
FTP_REMOTE_THEME=/public_html/wp-content/themes/jwellery-jewelry/
FTP_REMOTE_PLUGIN=/public_html/wp-content/plugins/jewelry-upi-store/
